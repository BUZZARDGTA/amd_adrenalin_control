{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run AMD Adrenalin Control",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"main.py"
			],
			"isBackground": false
		},
		{
			"label": "Lint All (Pylint)",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"pylint",
				"--rcfile=pyproject.toml",
				"main.py",
				"src/"
			],
			"group": "test",
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"clear": true
			},
			"problemMatcher": {
				"owner": "pylint",
				"fileLocation": ["relative", "${workspaceFolder}"],
				"pattern": {
					"regexp": "^(.+?):(\\d+):(\\d+):\\s+(\\w\\d+):\\s+(.+)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"code": 4,
					"message": 5
				}
			}
		}
	]
}